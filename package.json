{
  "name": "unimportant-pics",
  "version": "0.1.0",
  "private": true,
  "description": "AI-assisted iOS camera roll cleanup tool. Built with React Native + TypeScript, with a Vercel Function backend that proxies AI calls through Vercel AI Gateway.",
  "scripts": {
    "ios": "react-native run-ios",
    "start": "react-native start",
    "lint": "eslint .",
    "tsc": "tsc --noEmit",
    "test": "jest",
    "pods": "cd ios && pod install",
    "api:dev": "vercel dev",
    "api:tsc": "tsc -p api/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@react-native-camera-roll/camera-roll": "^7.8.0",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.10.0",
    "@shopify/flash-list": "^1.7.1",
    "react": "18.3.1",
    "react-native": "0.75.4",
    "react-native-gesture-handler": "^2.20.0",
    "react-native-permissions": "^4.1.5",
    "react-native-reanimated": "^3.15.4",
    "react-native-safe-area-context": "^4.11.0",
    "react-native-screens": "^3.34.0",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/preset-env": "^7.25.0",
    "@babel/runtime": "^7.25.0",
    "@react-native/babel-preset": "0.75.4",
    "@react-native/metro-config": "0.75.4",
    "@react-native/typescript-config": "0.75.4",
    "@types/react": "^18.3.3",
    "@types/react-test-renderer": "^18.3.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "react-test-renderer": "18.3.1",
    "typescript": "5.4.5"
  },
  "engines": {
    "node": ">=18"
  }
}
