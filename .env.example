# Native app endpoint for the Vercel Function. Leave unset to use local mock
# analysis in the Expo app.
EXPO_PUBLIC_ANALYSIS_API_URL=https://your-vercel-project.vercel.app/api/analyze-photos

# Optional shared key sent as `x-app-key`. If set on the server (APP_SHARED_KEY)
# the function rejects requests that don't match. Embedded in the client bundle,
# so treat this as soft rate-limiting, not authentication.
EXPO_PUBLIC_APP_SHARED_KEY=

# Server-only. Optional override of the Vercel AI Gateway model slug.
AI_GATEWAY_MODEL=anthropic/claude-sonnet-4-6

# Server-only. Must match EXPO_PUBLIC_APP_SHARED_KEY when set.
APP_SHARED_KEY=
